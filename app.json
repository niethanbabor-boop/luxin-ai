{
  "expo": {
    "name": "Luxin AI Assistant",
    "slug": "luxin-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "luxin-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#212121"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luxin.aiassistant"
    },
    "android": {
      "package": "com.luxin.aiassistant",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#212121"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "056a3bea-3718-49e1-90a0-acb03a7a17bb"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
